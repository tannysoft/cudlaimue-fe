# ===============================================
# Cudlaimue — Local shell env (.env.local)
# ===============================================
# Only needed for CLI tools (wrangler, drizzle-kit). Runtime secrets go in
# `.dev.vars` instead (see .dev.vars.example).

# Wrangler CLI — deploy token (account-wide permissions)
# Dashboard → My Profile → API Tokens → Create Token
# Scopes:
#   Account:  Workers Scripts:Edit, Pages:Edit, KV:Edit, R2:Edit, D1:Edit,
#             Account Settings:Read
#   Zone (cudlaimue.com):  Zone:Read, DNS:Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Drizzle studio (optional — only for browsing D1 from CLI)
D1_DATABASE_ID=
D1_TOKEN=
